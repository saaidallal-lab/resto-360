{
    "rewrites": [
        {
            "source": "/api/geocode/:path*",
            "destination": "https://api-adresse.data.gouv.fr/:path*"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ],
    "headers": [
        {
            "source": "/assets/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        },
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "Content-Encoding",
                    "value": "br"
                }
            ]
        }
    ]
}