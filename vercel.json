{
    "rewrites": [
        {
            "source": "/api/dvf/:path*",
            "destination": "/api/dvf"
        },
        {
            "source": "/api/geocode",
            "destination": "/api/geocode"
        },
        {
            "source": "/((?!api/).*)",
            "destination": "/index.html"
        }
    ],
    "headers": [
        {
            "source": "/assets/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        }
    ]
}